# Nexus Care AI — environment variables.
#
# Copy this file to `.env` for local dev. The .env file is in .gitignore — never
# commit it. Production reads these from Google Secret Manager via External
# Secrets Operator; the names below are the canonical names.

# --- API service (services/api) ---
# All API service vars are NEXUS_API_-prefixed so multiple services in the
# same shell don't collide.

NEXUS_API_ENVIRONMENT=development
NEXUS_API_DATABASE_URL=postgresql+psycopg://nexus:nexus@localhost:5433/nexus_care

# Local dev only: leave NEXUS_API_JWT_SIGNING_KEY unset and the service
# generates a fresh random key per startup. In staging/prod, set this to a
# strong random value (e.g., `openssl rand -base64 48`).
# NEXUS_API_JWT_SIGNING_KEY=

NEXUS_API_FRONTEND_ORIGIN=http://localhost:3000
NEXUS_API_LOG_LEVEL=INFO
NEXUS_API_SQL_ECHO=false

# --- Alembic ---
# Same DB as the API service. Standalone variable so `alembic upgrade head`
# works without booting the full app.
DATABASE_URL=postgresql+psycopg://nexus:nexus@localhost:5433/nexus_care

# --- Frontend (apps/web) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:18001
